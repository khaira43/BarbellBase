rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isMe(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function friendshipPairId(a, b) {
      return a < b ? a + '_' + b : b + '_' + a;
    }

    function areAcceptedFriends(uidA, uidB) {
      return exists(/databases/$(database)/documents/friendships/$(friendshipPairId(uidA, uidB)))
        && get(/databases/$(database)/documents/friendships/$(friendshipPairId(uidA, uidB))).data.status == 'accepted';
    }

    // Users — own doc fully writable; other users readable for handle/displayName lookups.
    match /users/{userId} {
      allow read: if isSignedIn();
      allow create, update: if isMe(userId);
      allow delete: if false;

      // Sessions are readable by the owner OR by accepted friends.
      match /sessions/{sessionId} {
        allow read: if isMe(userId) || areAcceptedFriends(request.auth.uid, userId);
        allow create, update, delete: if isMe(userId);
      }

      // Everything else under /users/{uid}/* is owner-only.
      match /workoutTemplates/{id}    { allow read, write: if isMe(userId); }
      match /customExercises/{id}     { allow read, write: if isMe(userId); }
      match /schedule/{id}            { allow read, write: if isMe(userId); }
      match /goals/{id}               { allow read, write: if isMe(userId); }
      match /bodyweightEntries/{id}   { allow read, write: if isMe(userId); }
    }

    // Username uniqueness index.
    match /usernames/{handle} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.user_id == request.auth.uid;
      allow delete: if isSignedIn()
        && resource.data.user_id == request.auth.uid;
      allow update: if false;
    }

    // Friendships — pairId is sorted([uidA, uidB]).join('_').
    match /friendships/{pairId} {
      allow read: if isSignedIn() && request.auth.uid in resource.data.users;

      // Create: requester must be me, status starts as pending.
      allow create: if isSignedIn()
        && request.resource.data.requester_id == request.auth.uid
        && request.auth.uid in request.resource.data.users
        && request.resource.data.users.size() == 2
        && request.resource.data.status == 'pending';

      // Update: only the non-requester can flip to accepted.
      allow update: if isSignedIn()
        && request.auth.uid in resource.data.users
        && resource.data.requester_id != request.auth.uid
        && resource.data.status == 'pending'
        && request.resource.data.status == 'accepted';

      // Delete (decline or unfriend): either party.
      allow delete: if isSignedIn() && request.auth.uid in resource.data.users;
    }
  }
}
